# ===========================================
# Récif Platform — Environment Variables
# ===========================================
# Copy to .env and adjust values for your environment.
# Profiles: dev (default), test, prod

# --- Environment Profile ---
ENV_PROFILE=dev  # dev | test | prod

# --- Database ---
DATABASE_URL=postgres://recif:recif_dev@localhost:5432/recif?sslmode=disable
POSTGRES_USER=recif
POSTGRES_PASSWORD=recif_dev
POSTGRES_DB=recif

# --- Service Ports ---
RECIF_PORT=8080
CORAIL_PORT=8000
DASHBOARD_PORT=3000

# --- Authentication ---
AUTH_ENABLED=false  # Set true for test/prod
JWT_SECRET=change-me-in-production
OIDC_ISSUER_URL=  # e.g. https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# --- Corail gRPC Connection ---
CORAIL_GRPC_ADDR=localhost:50051

# --- mTLS (Récif ↔ Corail) ---
MTLS_CERT_PATH=
MTLS_KEY_PATH=
MTLS_CA_PATH=

# --- Logging & Observability ---
LOG_LEVEL=debug  # debug | info | warn | error
LOG_FORMAT=text  # text | json
OTEL_EXPORTER=stdout  # stdout | otlp
OTEL_ENDPOINT=  # e.g. http://localhost:4317

# --- Rate Limiting ---
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# --- Git State (release artifacts) ---
RECIF_STATE_REPO=             # e.g. "my-org/recif-state"
RECIF_STATE_BRANCH=main
RECIF_STATE_TOKEN=            # GitHub PAT with repo write access

# --- MLflow ---
MLFLOW_URI=                   # e.g. http://mlflow:5000

# --- Agent Communication ---
AGENT_BASE_URL=http://%s.team-default.svc.cluster.local:8001
# AGENT_GRPC_URL=dns:///%s.team-default.svc.cluster.local:9001

# --- Knowledge Base ---
KB_DATABASE_URL=              # e.g. postgresql://recif:recif_dev@localhost:5432/corail_storage
